rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isKpmUser() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.email != null && 
             (request.auth.token.email.lower().endsWith('@moe-dl.edu.my') || 
              request.auth.token.email.lower().endsWith('@moe.gov.my'));
    }

    function isDevUser() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() == 'syahrulxy91@gmail.com';
    }

    function isPpdgmStaff() {
      return isKpmUser() || isDevUser();
    }

    // Semak data incoming (untuk create/update)
    function incomingData() {
      return request.resource.data;
    }

    // Semak data sedia ada (untuk update/delete)
    function existingData() {
      return resource.data;
    }

    function isValidInstitusiStubCreate(data) {
      return (('nama' in data && data.nama is string && data.nama.size() >= 1) || 
              ('namaInstitusi' in data && data.namaInstitusi is string && data.namaInstitusi.size() >= 1)) &&
             ('statusPendaftaran' in data && data.statusPendaftaran == 'didaftarkan-awal') &&
             ('statusProfil' in data && data.statusProfil == 'belum-mula') &&
             ('completionPercentage' in data && data.completionPercentage == 0) &&
             ('source' in data && data.source == 'ppdgm-name-only-registration') &&
             data.keys().size() <= 80;
    }

    function isValidInstitusiUpdate(data) {
      return (('nama' in data && data.nama is string && data.nama.size() >= 1) || 
              ('namaInstitusi' in data && data.namaInstitusi is string && data.namaInstitusi.size() >= 1)) &&
             (!('completionPercentage' in data) || (data.completionPercentage is int && data.completionPercentage >= 0 && data.completionPercentage <= 100)) &&
             (!('statusProfil' in data) || (data.statusProfil in ['belum-mula', 'sedang-dikemaskini', 'lengkap'])) &&
             data.keys().size() <= 80;
    }

    function isValidInstitusi(data) {
      return (('nama' in data && data.nama is string && data.nama.size() >= 1) || 
              ('namaInstitusi' in data && data.namaInstitusi is string && data.namaInstitusi.size() >= 1)) &&
             (('kategori' in data && data.kategori is string) || 
              ('jenis' in data && data.jenis is string)) &&
             (('status' in data && data.status in ['aktif', 'tidak aktif', 'digantung', 'didaftarkan-awal']) || 
              ('statusOperasi' in data && data.statusOperasi in ['aktif', 'tidak aktif', 'digantung', 'didaftarkan-awal']) || 
              ('statusPendaftaran' in data && (data.statusPendaftaran in ['aktif', 'tidak aktif', 'digantung', 'didaftarkan-awal'] || data.statusPendaftaran is string))) &&
             data.keys().size() <= 80;
    }

    function isValidKelas(data) {
      return ('namaKelas' in data && data.namaKelas is string) &&
             (('kapasiti' in data && data.kapasiti is int && data.kapasiti >= 1 && data.kapasiti <= 100) ||
              ('kapasitiMaksimum' in data && data.kapasitiMaksimum is int && data.kapasitiMaksimum >= 1 && data.kapasitiMaksimum <= 100));
    }

    function isValidMurid(data) {
      return ('nama' in data && data.nama is string) &&
             ('jantina' in data && data.jantina in ['Lelaki', 'Perempuan']);
    }

    function isValidGuru(data) {
      return ('nama' in data && data.nama is string) &&
             ('jawatan' in data && data.jawatan is string) &&
             (('noIc' in data && data.noIc is string && data.noIc.matches('^[0-9]{6}-[0-9]{2}-[0-9]{4}$')) ||
              ('icNumber' in data && data.icNumber is string && data.icNumber.matches('^[0-9]{6}-[0-9]{2}-[0-9]{4}$')));
    }

    function isValidProgram(data) {
      return ('tarikh' in data && data.tarikh is string) &&
             ('status' in data && data.status is string) &&
             (('namaProgram' in data && data.namaProgram is string) || 
              ('nama' in data && data.nama is string));
    }

    function isValidBorangCreate(data) {
      return ('jenisBorang' in data && data.jenisBorang is string) &&
             ('institusiId' in data && data.institusiId is string && data.institusiId.size() > 5) &&
             ('createdAt' in data && data.createdAt is timestamp) &&
             (data.status in ['draf', 'hantar', 'dikemukakan']);
    }

    function isValidBorangUpdate(data, oldData) {
      // KPM / Dev users bypass general client restrictions (approval rights)
      return isPpdgmStaff() || (
        oldData.status == 'draf' &&
        (data.status == 'hantar' || data.status == 'dikemukakan') &&
        // 'lulus', 'tolak', 'diluluskanOleh' are read-only fields from general client
        !('lulus' in data.diff(oldData).affectedKeys() ||
          'tolak' in data.diff(oldData).affectedKeys() ||
          'diluluskanOleh' in data.diff(oldData).affectedKeys())
      );
    }

    // 1. Match for Institusi Public (safe list for login dropdown)
    match /institusiPublic/{institusiId} {
      allow read: if request.auth != null;
      allow write: if isPpdgmStaff();
    }

    // 2. Match for Institusi and its subcollections
    match /institusi/{institusiId} {
      allow read: if isPpdgmStaff() || 
                  (request.auth != null && 
                   resource.data.get('portalAccess', null) != null && 
                   resource.data.portalAccess.get('authUid', '') == request.auth.uid);
      
      allow create: if isPpdgmStaff() && isValidInstitusiStubCreate(incomingData());
      
      allow update: if isPpdgmStaff() || 
                    (request.auth != null && 
                     (
                       (resource.data.get('portalAccess', null) != null && resource.data.portalAccess.get('authUid', '') == request.auth.uid) ||
                       (
                         resource.data.get('portalAccess', null) != null && 
                         (resource.data.portalAccess.get('authUid', '') == '' || resource.data.portalAccess.get('authUid', null) == null) &&
                         resource.data.portalAccess.get('credentialStatus', '') != 'disekat' &&
                         resource.data.portalAccess.get('authStatus', '') != 'disekat' &&
                         incomingData().get('portalAccess', null) != null &&
                         incomingData().portalAccess.get('authUid', '') == request.auth.uid
                       ) ||
                       (
                         resource.data.get('portalAccess', null) == null &&
                         incomingData().get('portalAccess', null) != null &&
                         incomingData().portalAccess.get('authUid', '') == request.auth.uid
                       )
                     ) &&
                     isValidInstitusiUpdate(incomingData()));
      allow delete: if false;

      // Sub-collections: /kelas, /murid, /guru, /program
      match /kelas/{kelasId} {
        allow read: if true;
        allow create, update: if isPpdgmStaff() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.get('portalAccess', null) != null &&
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.portalAccess.get('authUid', '') == request.auth.uid && 
                     isValidKelas(incomingData()));
        allow delete: if false;
      }

      match /murid/{muridId} {
        allow read: if true;
        allow create, update: if isPpdgmStaff() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.get('portalAccess', null) != null &&
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.portalAccess.get('authUid', '') == request.auth.uid && 
                     isValidMurid(incomingData()));
        allow delete: if false;
      }

      match /guru/{guruId} {
        allow read: if true;
        allow create, update: if isPpdgmStaff() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.get('portalAccess', null) != null &&
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.portalAccess.get('authUid', '') == request.auth.uid && 
                     isValidGuru(incomingData()));
        allow delete: if false;
      }

      match /program/{programId} {
        allow read: if true;
        allow create, update: if isPpdgmStaff() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.get('portalAccess', null) != null &&
                     get(/databases/$(database)/documents/institusi/$(institusiId)).data.portalAccess.get('authUid', '') == request.auth.uid && 
                     isValidProgram(incomingData()));
        allow delete: if false;
      }
    }

    // Match for Pematuhan
    match /pematuhan/{pematuhanId} {
      allow read: if true;
      allow write: if false;
    }

    // Match for Tindakan
    match /tindakan/{tindakanId} {
      allow read: if true;
      allow write: if false;
    }

    // 3. Match for Borang
    match /borang/{borangId} {
      allow read: if true;
      allow create: if isPpdgmStaff() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/institusi/$(incomingData().institusiId)).data.get('portalAccess', null) != null &&
                     get(/databases/$(database)/documents/institusi/$(incomingData().institusiId)).data.portalAccess.get('authUid', '') == request.auth.uid && 
                     isValidBorangCreate(incomingData()));
      allow update: if isPpdgmStaff() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/institusi/$(resource.data.institusiId)).data.get('portalAccess', null) != null &&
                     get(/databases/$(database)/documents/institusi/$(resource.data.institusiId)).data.portalAccess.get('authUid', '') == request.auth.uid && 
                     isValidBorangUpdate(incomingData(), existingData()));
      allow delete: if false;
    }

    // 4. Match for Reminders
    match /reminders/{reminderId} {
      allow read: if true;
      allow write: if false;
    }

    // 5. Match for Audit Logs
    match /audit_logs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // 6. Match for Users
    match /users/{userId} {
      allow read, write: if false;
    }
  }
}
